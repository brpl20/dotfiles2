# Search uteis file
alias ss="search_term_in_my_file"
search_term_in_my_file() {
    local file="$UTEIS"
    if [[ -z "$file" ]]; then
        echo "UTEIS not set"
        return 1
    fi
    if [[ "$1" == "#" ]]; then
        # Header search: ss # docker → finds ## Docker header and prints full section
        awk -v term="$2" '
        BEGIN { IGNORECASE = 1 }
        /^#+/ && tolower($0) ~ tolower(term) {
            if (found) print "---"
            found = 1
            match($0, /^#+/)
            level = RLENGTH
            print
            next
        }
        found && /^#+/ {
            match($0, /^#+/)
            if (RLENGTH <= level) found = 0
            else print
            next
        }
        found { print }
        ' "$file" | tee >($CLIP)
    else
        # General search: ss h3
        # Regular lines print as-is; header matches expand to full section
        awk -v term="$1" '
        BEGIN { IGNORECASE = 1 }
        in_section && /^#+/ {
            match($0, /^#+/)
            if (RLENGTH <= sec_level) {
                in_section = 0
            } else {
                print
                next
            }
        }
        in_section { print; next }
        tolower($0) ~ tolower(term) {
            if (/^#+/) {
                if (NR > 1) print "---"
                print $0
                match($0, /^#+/)
                sec_level = RLENGTH
                in_section = 1
            } else {
                print $0
            }
        }
        ' "$file"
    fi
}
